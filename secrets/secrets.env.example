# Dotfiles secrets — TEMPLATE.
#
#   cp secrets.env.example secrets.env   &&   $EDITOR secrets.env
#
# secrets.env is gitignored and NEVER committed/pushed. install.sh wires
# ~/.bashrc to source it, so tools that reference {env:VAR} (opencode) or
# ${VAR} can resolve the values, and install.sh uses it to materialize the
# real Cursor mcp.json from mcp.json.example.

# Node bin dir for Cursor MCP servers launched via npx (see mcp.json.example).
# Leave empty to let install.sh auto-detect via `command -v node`.
export NODE_BIN_PATH=

# --- MCP / agentic-tool keys ---
export FIRECRAWL_API_KEY=
export BROWSERBASE_API_KEY=
export BROWSERBASE_PROJECT_ID=
export GEMINI_API_KEY=
export AGENTMEMORY_SECRET=
export GITHUB_TOKEN=

# --- Other dev keys (carried over for convenience on a new machine) ---
export GH_TOKEN=
export ANTHROPIC_API_KEY=
export LINEAR_API_KEY=
